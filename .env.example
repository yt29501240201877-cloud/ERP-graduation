# Base URL of the real backend API.
# When unset, the app falls back to /api (see src/services/api.js).
REACT_APP_API_BASE_URL=http://localhost:4000/api

# Set to "false" once a real backend is available to switch off
# the built-in mock data (see src/services/invoiceService.js).
REACT_APP_USE_MOCK=true
